# The ID of a *public* Google Spreadsheet ("Anyone with the link can view").
# It is the part of the URL between /spreadsheets/d/ and /edit.
# Leave unset to use the bundled sample data in data/sample.csv.
SHEET_ID=

# Optional: the gid of the tab to read (defaults to 0, the first tab).
SHEET_GID=0

# Optional: absolute URL of the deployed site, used for metadata/sitemap.
SITE_URL=
